# xinference 推理后端 layer - M01 阶段交付物 D-M01-03
# copaw-dpo-infer-xinfer:latest

FROM copaw-dpo-base:latest

LABEL maintainer="ant-group-dpo-team" \
      version="1.0" \
      description="xinference 推理后端 layer (备选推理方案)"

# 安装 xinference 与相关依赖
RUN pip install --no-cache-dir \
        xinference==0.15.4 \
        xinference-client==0.15.4 \
        openai==1.40.0 \
        fastapi==0.112.0 \
        uvicorn[standard]==0.30.5 \
        pydantic==2.8.2

# 验证
RUN python -c "import xinference; print(f'xinference={xinference.__version__}')" \
    && xinference --version 2>/dev/null || echo "xinference CLI installed"

WORKDIR /workspace
CMD ["/bin/bash"]
